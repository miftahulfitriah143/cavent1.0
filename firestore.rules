rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────
    // HELPER FUNCTIONS
    // ─────────────────────────────────────────────────────────────

    // Apakah user sudah login?
    function isSignedIn() {
      return request.auth != null;
    }

    // Apakah ini dokumen milik user yang login?
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Ambil data role user dari koleksi users
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Apakah user memiliki role admin?
    function isAdmin() {
      return isSignedIn() && getUserRole() == 'admin';
    }

    // Apakah user memiliki role organizer?
    function isOrganizer() {
      return isSignedIn() && getUserRole() == 'organizer';
    }

    // Apakah user memiliki role audiens?
    function isAudiens() {
      return isSignedIn() && getUserRole() == 'audiens';
    }

    // ─────────────────────────────────────────────────────────────
    // KOLEKSI: users
    // ─────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Siapa saja yang login bisa baca profil sendiri
      allow read: if isSignedIn() && isOwner(userId);

      // Admin bisa baca semua profil user
      allow read: if isAdmin();

      // User bisa buat dokumen profil sendiri (saat register)
      allow create: if isSignedIn() && isOwner(userId);

      // User bisa update profil sendiri (kecuali role dan isActive); admin bisa update semua
      allow update: if isSignedIn() && (
        (isOwner(userId) && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isActive']))) || 
        isAdmin()
      );

      // Hanya admin yang bisa hapus
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────
    // KOLEKSI: events
    // ─────────────────────────────────────────────────────────────
    match /events/{eventId} {
      // Semua orang (termasuk yang belum login) bisa melihat acara yang berstatus 'published'.
      // Admin & Organizer (pemilik acara) bisa melihat seluruh event (termasuk draft/rejected).
      allow read: if resource.data.status == 'published' || 
                  (isSignedIn() && (isAdmin() || (isOrganizer() && resource.data.organizerId == request.auth.uid)));
      
      // Organizer bisa buat acara (harus mencantumkan organizerId mereka sendiri)
      allow create: if isOrganizer() && request.resource.data.organizerId == request.auth.uid;
      
      // Admin HANYA bisa update status approval. Organizer bisa update acaranya sendiri. Mahasiswa hanya bisa update registeredCount saat mendaftar.
      allow update: if isSignedIn() && (
        (isAdmin() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'approvedAt', 'rejectedAt', 'rejectionReason'])) || 
        (isOrganizer() && resource.data.organizerId == request.auth.uid) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['registeredCount']))
      );

      // Admin dan organizer pemilik bisa hapus
      allow delete: if isAdmin() || (isOrganizer() && resource.data.organizerId == request.auth.uid);
    }

    // ─────────────────────────────────────────────────────────────
    // KOLEKSI: registrations
    // ─────────────────────────────────────────────────────────────
    match /registrations/{regId} {
      // Mahasiswa bisa baca pendaftaran miliknya sendiri
      // Organizer bisa baca pendaftaran untuk event miliknya
      // Admin bisa baca semua
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.organizerId == request.auth.uid ||
        isAdmin()
      );

      // Mahasiswa yang sudah login bisa mendaftar atas namanya sendiri
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;

      // Mahasiswa bisa update (batalkan) pendaftaran sendiri
      // Organizer bisa update (absensi) untuk event miliknya
      // Admin bisa update semua
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.organizerId == request.auth.uid ||
        isAdmin()
      );

      // Mahasiswa bisa hapus (batalkan) pendaftaran sendiri
      allow delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );
    }

    // ─────────────────────────────────────────────────────────────
    // KOLEKSI: reviews
    // ─────────────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      // Semua orang (termasuk yang belum login) bisa membaca semua review untuk referensi acara.
      allow read: if true;

      // Mahasiswa yang sudah absen bisa buat review atas namanya sendiri
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;

      // Hanya penulis review yang bisa update/hapus
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ─────────────────────────────────────────────────────────────
    // KOLEKSI: notifications
    // ─────────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      // User bisa baca notifikasi yang ditujukan untuk mereka
      // Admin bisa baca semua notifikasi
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.targetRole == getUserRole() ||
        isAdmin()
      );

      // Admin & Organizer bisa buat notifikasi apa saja
      // Audiens hanya boleh membuat notifikasi pendaftaran (NEW_REGISTRATION)
      allow create: if isSignedIn() && (
        isAdmin() || 
        isOrganizer() || 
        request.resource.data.type == 'NEW_REGISTRATION'
      );

      // User bisa update (mark as read) notifikasi milik mereka
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );

      // Hanya admin yang bisa hapus notifikasi
      allow delete: if isAdmin();
    }
  }
}
